#!/usr/bin/env python3
"""
Pre-commit hook for mynews
Validation rules:
1. Only 11 approved top-level directories under answers/
2. Only .md files checked (others skipped)
3. Filename: Chinese/alphanumeric/_-(). allowed, no spaces, no special chars
4. No path traversal (..)
5. Exact depth: answers/domain/subdomain/file.md (exactly 4 parts/3 slashes)
6. Content is in flomo format:
   - Tags on the first line (# or @ prefix, ≥3)
   - No Markdown headers (# ## ### etc.)
   - No blockquotes (>)
   - No code blocks (```)
   - No links [text](url) or images ![](url)
   - No horizontal rules (---)
   - No tables (|)
   - Allowed: **bold**, <mark>highlight</mark>, <u>underline</u>, - lists, 1. ordered lists
"""

import subprocess
import sys
import re
import os

ALLOWED_TOP_DIRS = {
    "医学", "安全", "技术", "政治", "教育科学", "法律",
    "游戏", "社会科学", "管理", "经济", "自然科学"
}

ALLOWED_ROOT_FILES = {
    "README.md", "SKILL.md", "AGENTS.md", "ROADMAP.md", "_sidebar.md",
    "_welcome.md", "P0Audit.md", "setup_hooks.sh", ".gitignore"
}

FILENAME_PATTERN = re.compile(r'^[a-zA-Z0-9\u4e00-\u9fff()\.]+$')
PATH_TRAVERSAL = re.compile(r'\.\.')

FORBIDDEN_PATTERNS = [
    (re.compile(r'^#+\s+', re.MULTILINE), "Markdown 标题 (# ## ### 等) flomo 不支持"),
    (re.compile(r'^>\s+', re.MULTILINE), "引用块 (> xxx) flomo 不支持"),
    (re.compile(r'```'), "代码块 (```) flomo 不支持"),
    (re.compile(r'\[.+?\]\(.+?\)'), "链接格式 [标题](链接) flomo 不支持"),
    (re.compile(r'!\[.*?\]\(.+?\)'), "图片格式 ![](url) flomo 不支持"),
    (re.compile(r'^---+$', re.MULTILINE), "水平线 (---) flomo 不支持"),
    (re.compile(r'^\|.+\|$', re.MULTILINE), "Markdown 表格 flomo 不支持"),
]


def decode_git_path(path):
    return path


def validate_filename(filename):
    if not filename:
        return False, "空文件名"
    if ' ' in filename:
        return False, "文件名包含空格"
    if not FILENAME_PATTERN.match(filename):
        return False, "文件名包含非法字符（允许：中文/字母/数字/_-().）"
    return True, ""


def validate_content(content):
    errors = []
    lines = content.split('\n')

    # 1. Tags must be on first line
    if not lines or not lines[0].strip():
        errors.append("文件第一行不能为空，必须是标签行")
    else:
        first_line = lines[0].strip()
        tags = re.findall(r'[#@][^\s#@]+', first_line)
        if len(tags) < 3:
            errors.append(f"标签数量不足3个，当前{len(tags)}个：第一行必须是标签行")

    # 2. Forbidden patterns
    for pattern, msg in FORBIDDEN_PATTERNS:
        if pattern.search(content):
            errors.append(msg)

    # 3. Must have a bold title (no Markdown header)
    has_bold_title = bool(re.search(r'^\*\*[^*]+\*\*$', content, re.MULTILINE))
    if not has_bold_title:
        errors.append("缺少加粗标题（**xxx**），例如：**领域_二级领域_知识点**")

    return errors


def main():
    result = subprocess.run(
        ["git", "-c", "core.quotePath=false", "diff-index", "--cached", "--name-only", "--diff-filter=AM", "HEAD"],
        capture_output=True, text=True, encoding="utf-8"
    )
    staged_files = [f for f in result.stdout.split("\n") if f.strip()]

    errors = []

    for file in staged_files:
        decoded_file = decode_git_path(file)

        if not file.endswith(".md"):
            continue

        filename = os.path.basename(decoded_file)
        if filename in ALLOWED_ROOT_FILES:
            continue

        if PATH_TRAVERSAL.search(decoded_file):
            errors.append((file, "路径遍历 (..) 不允许"))
            continue

        parts = decoded_file.split(os.sep)

        if len(parts) < 2:
            errors.append((file, "缺少顶级目录"))
            continue

        if len(parts) != 4:
            depth = len(parts) - 1
            errors.append((file, f"路径深度必须是4层(answers/领域/二级领域/文件名.md)，当前{depth}层"))
            continue

        top_dir = parts[1]

        if top_dir not in ALLOWED_TOP_DIRS:
            errors.append((file, f"顶级目录 '{top_dir}' 不在白名单内"))
            continue

        valid, msg = validate_filename(filename)
        if not valid:
            errors.append((file, f"文件名问题: {msg}"))

        if len(parts) == 4 and parts[0] == "answers":
            try:
                content_result = subprocess.run(
                    ["git", "show", f":{file}"],
                    capture_output=True, text=True, encoding="utf-8"
                )
                if content_result.returncode == 0:
                    content_errors = validate_content(content_result.stdout)
                    for err in content_errors:
                        errors.append((file, f"内容格式: {err}"))
            except Exception:
                pass

    if errors:
        print("pre-commit hook 验证失败:")
        print()
        by_type = {}
        for file, reason in errors:
            if reason not in by_type:
                by_type[reason] = []
            by_type[reason].append(file)

        for reason, files in by_type.items():
            print(f"【{reason}】")
            for f in files:
                print(f"  - {f}")
            print()

        print("允许的顶级目录:", " ".join(sorted(ALLOWED_TOP_DIRS)))
        print()
        print("解决方案:")
        print("1. 文件名只允许: 中文/字母/数字/()/ .")
        print("2. 路径格式: answers/领域/二级领域/文件名.md (必须4层)")
        print("3. 第一行必须是标签 (#xxx 或 @xxx), ≥3 个")
        print("4. 必须用 **加粗** 代替 ## 标题")
        print("5. flomo 不支持: 标题/引用/代码块/链接/图片/水平线/表格")
        sys.exit(1)

    sys.exit(0)


if __name__ == "__main__":
    main()
