#!/usr/bin/env python3
# Pre-commit hook for mynews
#
# USAGE:
#   文件路径: answers/领域/二级领域/知识点.md  (4层，不含空格)
#   文件名:  领域_二级领域_知识点.md         (3段式，段内不含空格)
#   标签:    第一行，≥3个，# 或 @ 前缀
#   标题:    **领域_二级领域_知识点**        (加粗，必须以 文件名前两段_ 开头)
#
# Validation rules:
# 1. Only 11 approved top-level directories under answers/
# 2. Only .md files checked (others skipped)
# 3. Filename: Chinese/alphanumeric/underscore-dash-parentheses-dot allowed, no spaces, no special chars
# 4. No path traversal (..)
# 5. Exact depth: answers/domain/subdomain/file.md (exactly 4 parts/3 slashes)
# 6. Content is in flomo format:
#    - Tags on the first line (# or @ prefix, ≥3)
#    - No Markdown headers (# ## ### etc.)
#    - No blockquotes (>)
#    - No code blocks (```)
#    - No links [text](url) or images ![](url)
#    - No horizontal rules (---)
#    - No tables (|)
#    - Allowed: **bold**, <mark>highlight</mark>, <u>underline</u>, - lists, 1. ordered lists
# 7. Title similarity check: warns if a file with a similar title already exists
#    in the same subdomain directory in git history. Warns only, does not block.
# 8. Bold title末尾禁止 _ 分隔符（会触发 MCP server 将内部所有 _ 转义）

import subprocess
import sys
import re
import os
from pathlib import Path

ALLOWED_TOP_DIRS = {
    "医学", "安全", "技术", "政治", "教育科学", "法律",
    "游戏", "社会科学", "管理", "经济", "自然科学"
}

ALLOWED_ROOT_FILES = {
    "README.md", "SKILL.md", "AGENTS.md", "ROADMAP.md", "_sidebar.md",
    "_welcome.md", "P0Audit.md", "setup_hooks.sh", ".gitignore"
}

# 非 answers/ 路径不进行 4 层深度和 flomo 格式检查（基础设施文件）
INFRA_PREFIXES = (".opencode/", "scripts/", "docs/")

FILENAME_PATTERN = re.compile('^[a-zA-Z0-9_\\-\\.\\u4e00-\\u9fff()]+$')
PATH_TRAVERSAL = re.compile(r'\.\.')

FORBIDDEN_PATTERNS = [
    # 匹配 ## Title, ### Title 等；不匹配 #tag 和 # tag（标签格式）
    (re.compile(r'^#{2,}\s+\S|^#\s+[^#\s@]', re.MULTILINE), "Markdown 标题 (# ## ### 等) flomo 不支持"),
    (re.compile(r'^>\s+', re.MULTILINE), "引用块 (> xxx) flomo 不支持"),
    (re.compile(r'```'), "代码块 (```) flomo 不支持"),
    (re.compile(r'\[.+?\]\(.+?\)'), "链接格式 [标题](链接) flomo 不支持"),
    (re.compile(r'!\[.*?\]\(.+?\)'), "图片格式 ![](url) flomo 不支持"),
    (re.compile(r'^---+$', re.MULTILINE), "水平线 (---) flomo 不支持"),
    (re.compile(r'^\|.+\|$', re.MULTILINE), "Markdown 表格 flomo 不支持"),
]

# 检测加粗标题末尾的 _ 分隔符（会导致 MCP server 将内部所有 _ 转义）
BOLD_TRAILING_UNDERSCORE = re.compile(r'\*\*[^*]*_\*\*$')


STOP_WORDS = {
    '与', '或', '的', '和', '及', '在', '对', '为', '了', '是',
    '一', '个', '上', '下', '中', '以', '等', '于', '把',
    '被', '用', '到', '从', '向', '由', '但', '却',
    '给', '并', '也', '又', '即', '如', '则', '所',
    '不', '有', '这', '那', '而', '需', '要', '可', '能', '说',
    '们', '来', '去', '做', '说', '道', '得'
}


def decode_git_path(path):
    return path


def split_segments(name_part):
    """Split filename into 3 segments (domain_subdomain_knowledge).
    English/acronym sequences are merged into one segment.
    Example: '真武T-Head_SAIL软件栈开源' -> ['真武', 'T-Head_SAIL', '软件栈开源']
    NOTE: If the knowledge part contains underscores that make it >3 segments,
    use hyphens instead: '真武T-Head-SAIL软件栈开源' gives 3 clean segments.
    """
    raw_parts = name_part.split('_')
    segments = []
    current = []
    for part in raw_parts:
        if re.match(r'^[a-zA-Z0-9]+(-[a-zA-Z0-9]+)*$', part):
            # Pure English (possibly hyphenated) — group with adjacent English
            current.append(part)
        else:
            if current:
                segments.append('-'.join(current))
                current = []
            segments.append(part)
    if current:
        segments.append('-'.join(current))
    return segments


def validate_filename(filename):
    if not filename:
        return False, "空文件名"
    if ' ' in filename:
        return False, "文件名包含空格"
    if not FILENAME_PATTERN.match(filename):
        return False, "文件名包含非法字符（允许：中文/字母/数字/_-().）"
    name_part = filename[:-3] if filename.endswith('.md') else filename
    parts = split_segments(name_part)
    if len(parts) != 3:
        return False, f"文件名必须三段式（领域_二级领域_知识点.md），当前 {len(parts)} 段: {filename} => 分段={parts}；如知识点含英文缩写，请用连字符-代替下划线_分隔（如：T-Head-SAIL）"
    if len(parts[0]) < 1 or len(parts[1]) < 1:
        return False, f"领域/二级领域不能为空: {filename}"
    return True, ""


def validate_content(content, filename):
    errors = []
    lines = content.split('\n')

    if not lines or not lines[0].strip():
        errors.append("文件第一行不能为空，必须是标签行")
    else:
        first_line = lines[0].strip()
        tags = re.findall(r'[#@][^\s#@]+', first_line)
        if len(tags) < 3:
            errors.append(f"标签数量不足3个，当前{len(tags)}个：第一行必须是标签行")
        SIGNAL_TYPES = {'#趋势信号', '#知识基座', '#信号笔记', '#分析框架', '#知识载体'}
        if not any(t in tags for t in SIGNAL_TYPES):
            errors.append(f"标签必须含 #信号类型 之一: {SIGNAL_TYPES}")

    for pattern, msg in FORBIDDEN_PATTERNS:
        if pattern.search(content):
            errors.append(msg)

    has_bold_title = bool(re.search(r'^\*\*[^*]+\*\*$', content, re.MULTILINE))
    if not has_bold_title:
        errors.append("缺少加粗标题（**xxx**），例如：**领域_二级领域_知识点**")
    else:
        first_title_match = re.search(r'^\*\*([^*]+)\*\*$', content, re.MULTILINE)
        if first_title_match:
            title = first_title_match.group(1)
            # 检查加粗内容末尾是否有 _ 分隔符（MCP server 会将其后所有 _ 转义）
            if title.endswith('_'):
                errors.append(f"加粗标题末尾不允许 _ 分隔符（'{title}_' 会触发 MCP server 转义问题，去掉末尾的 _）")
            name_no_ext = filename[:-3] if filename.endswith('.md') else filename
            file_prefix = '_'.join(name_no_ext.split('_')[:2])
            if not title.startswith(file_prefix + '_'):
                errors.append(f"加粗标题 '{title}' 必须以 '{file_prefix}_' 开头")

        found_title_idx = -1
        for i, line in enumerate(lines):
            if line.strip() == f"**{first_title_match.group(1)}**":
                found_title_idx = i
                break

        # 检查来源行
        has_source = bool(re.search(r'\*\*来源[^：:]*[：:]\s*.+', content))
        if not has_source:
            errors.append("缺少来源行，必须是 '**来源**：xxx' 或 '**来源: xxx'")

        # 检查概念和子概念
        has_concept = bool(re.search(r'^\*\*概念\*\*：', content, re.MULTILINE))
        if not has_concept:
            errors.append("缺少 '**概念**：xxx' 段落")

        has_subconcept = bool(re.search(r'^\*\*子概念\*\*[：:]', content, re.MULTILINE))
        if not has_subconcept:
            errors.append("缺少 '**子概念**：' 段落")

    return errors


def extract_title_keywords(filename):
    # 从文件名提取主要关键词，使用字符 n-gram 方法
    name = filename.replace('.md', '')
    parts = name.split('_')
    if len(parts) >= 3:
        keyword_part = '_'.join(parts[2:])
    else:
        keyword_part = name

    cleaned = re.sub(r'[-_.]+', '', keyword_part)
    keywords = []

    chinese_chars = re.findall(r'[\u4e00-\u9fff]+', cleaned)
    for chars in chinese_chars:
        if len(chars) >= 2:
            keywords.extend([chars[i:i+2] for i in range(len(chars)-1)])

    english_words = re.findall(r'[a-zA-Z0-9]{2,}', keyword_part)
    keywords.extend(english_words)

    keywords = [kw for kw in keywords if kw not in STOP_WORDS]

    return set(keywords)


def check_filename_collision(decoded_file):
    """检查 answers/ 目录下是否有完全同名的已存在文件（工作树）。"""
    if not decoded_file.startswith("answers/"):
        return []
    existing = Path(decoded_file)
    if existing.exists():
        return [decoded_file]
    return []


def check_similar_titles(decoded_file, filename):
    # 检查同子目录下是否有相似标题的旧文件
    parts = decoded_file.split(os.sep)
    if len(parts) < 3:
        return []

    domain = parts[1]
    subdomain = parts[2]
    target_keywords = extract_title_keywords(filename)
    if not target_keywords:
        return []

    try:
        result = subprocess.run(
            ["git", "-c", "core.quotePath=false", "ls-files",
             f"answers/{domain}/{subdomain}/"],
            capture_output=True, text=True, encoding="utf-8"
        )
        if result.returncode != 0:
            return []
    except Exception:
        return []

    existing_files = [f for f in result.stdout.split("\n") if f.strip().endswith(".md")]

    target_full = os.path.basename(decoded_file).replace('.md', '').split('_', 2)[-1] if '_' in os.path.basename(decoded_file) else os.path.basename(decoded_file).replace('.md', '')
    similar = []

    for existing in existing_files:
        existing_full = os.path.basename(existing).replace('.md', '').split('_', 2)[-1] if '_' in os.path.basename(existing) else os.path.basename(existing).replace('.md', '')
        if existing_full == target_full:
            continue

        existing_keywords = extract_title_keywords(os.path.basename(existing))

        shared = target_keywords & existing_keywords
        if not target_keywords or not existing_keywords:
            continue

        if len(shared) >= 3:
            similarity = len(shared) / max(len(target_keywords), len(existing_keywords))
            similar.append((existing, similarity, shared))

    return similar


def get_staged_files(use_head=True):
    """Get list of staged files. Pass use_head=False for --staged mode (works without prior commits)."""
    if use_head:
        result = subprocess.run(
            ["git", "-c", "core.quotePath=false", "diff-index",
             "--cached", "--name-only", "--diff-filter=AM", "HEAD"],
            capture_output=True, text=True, encoding="utf-8"
        )
        return [f for f in result.stdout.split("\n") if f.strip()]
    else:
        # --staged mode without HEAD: use git status --porcelain -z (null-terminated, no quoting issues)
        result = subprocess.run(
            ["git", "status", "--porcelain", "-z"],
            capture_output=True, text=True, encoding="utf-8"
        )
        if not result.stdout:
            return []
        # Format: "XY filename\0" — we want lines starting with "A " (staged added)
        entries = result.stdout.split('\0')
        staged = []
        for entry in entries:
            if len(entry) >= 3 and entry[0:2] == 'A ':
                staged.append(entry[3:])
        return staged


def main():
    import argparse
    parser = argparse.ArgumentParser(description="mynews flomo format validator")
    parser.add_argument("--staged", action="store_true",
                        help="验证当前 staged 文件，不创建 commit（用于自动化流水线）")
    parser.add_argument("--auto-fix", action="store_true",
                        help="自动修复常见格式问题（添加缺失的段落标记）")
    args = parser.parse_args()

    staged_files = get_staged_files(use_head=not args.staged)
    errors = []
    warnings = []

    mode_note = " [--staged 模式，无需 commit]" if args.staged else ""

    for file in staged_files:
        decoded_file = decode_git_path(file)

        if not file.endswith(".md"):
            continue

        filename = os.path.basename(decoded_file)
        if filename in ALLOWED_ROOT_FILES:
            continue

        # 基础设施目录（.opencode/, scripts/, docs/）跳过 answers/ 专属检查
        if decoded_file.startswith(INFRA_PREFIXES):
            continue

        if PATH_TRAVERSAL.search(decoded_file):
            errors.append((file, "路径遍历 (..) 不允许"))
            continue

        parts = decoded_file.split(os.sep)

        if len(parts) < 2:
            errors.append((file, "缺少顶级目录"))
            continue

        if len(parts) != 4:
            depth = len(parts) - 1
            fix = f"在 answers/ 下创建正确层级目录，如: mkdir -p answers/技术/AI芯片/"
            errors.append((file, f"路径深度必须是4层(answers/领域/二级领域/文件名.md)，当前{depth}层", fix))
            continue

        top_dir = parts[1]

        if top_dir not in ALLOWED_TOP_DIRS:
            fix = f"顶级目录必须为以下之一: {' '.join(sorted(ALLOWED_TOP_DIRS))}；将文件移动到正确目录下"
            errors.append((file, f"顶级目录 '{top_dir}' 不在白名单内", fix))
            continue

        name_part = filename[:-3] if filename.endswith('.md') else filename
        name_first_part = name_part.split('_')[0]
        if name_first_part != top_dir:
            fix = f"将文件名第一段改为 '{top_dir}'，或移动文件到 answers/{name_first_part}/ 目录"
            errors.append((file, f"文件名第一段 '{name_first_part}' 必须等于顶级目录名 '{top_dir}'", fix))

        valid, msg = validate_filename(filename)
        if not valid:
            fix = "用连字符-代替知识点部分的下划线_（尤其当含英文缩写时），如：真武T-Head-SAIL软件栈开源.md"
            errors.append((file, f"文件名问题: {msg}", fix))

        if len(parts) == 4 and parts[0] == "answers":
            try:
                content_result = subprocess.run(
                    ["git", "show", f":{file}"],
                    capture_output=True, text=True, encoding="utf-8"
                )
                if content_result.returncode == 0:
                    content_errors = validate_content(content_result.stdout, filename)
                    for err in content_errors:
                        errors.append((file, f"内容格式: {err}"))
            except Exception:
                pass

            similar_files = check_similar_titles(decoded_file, filename)
            for similar_file, similarity, shared in similar_files:
                warnings.append((
                    file,
                    f"同子目录下已有相似标题文档: {similar_file} "
                    f"(共享关键词: {', '.join(sorted(shared)[:5])}{'...' if len(shared) > 5 else ''}, 相似度: {similarity:.0%})"
                ))

            # 文件完全同名检测
            collisions = check_filename_collision(decoded_file)
            for coll in collisions:
                fix = "删除本地旧文件后再提交: git rm " + coll
                errors.append((file, f"文件已存在（同名冲突）: {coll}", fix))

    if errors:
        print("验证失败:" if args.staged else "pre-commit hook 验证失败:")
        print()
        by_type = {}
        for entry in errors:
            file = entry[0]
            reason = entry[1] if len(entry) > 1 else entry
            fix = entry[2] if len(entry) > 2 else ""
            if reason not in by_type:
                by_type[reason] = {"files": [], "fix": fix}
            by_type[reason]["files"].append(file)

        for reason, data in by_type.items():
            print(f"【{reason}】")
            for f in data["files"]:
                print(f"  - {f}")
            if data["fix"]:
                print(f"  💡 修复: {data['fix']}")
            print()

        print("允许的顶级目录:", " ".join(sorted(ALLOWED_TOP_DIRS)))
        print()
        print("解决方案:")
        print("1. 文件名只允许: 中文/字母/数字/()/ .")
        print("2. 路径格式: answers/领域/二级领域/文件名.md (必须4层)")
        print("3. 第一行必须是标签 (#xxx 或 @xxx), ≥3 个")
        print("4. 必须用 **加粗** 代替 ## 标题")
        print("5. 文档结构: **来源**：→ **概念**：→ **子概念**：(必须全部有)")
        print("6. flomo 不支持: 标题/引用/代码块/链接/图片/水平线/表格")
        if args.staged:
            print("提示: 用 --staged 模式运行，跳过 commit 直接验证 staged 文件")
        sys.exit(1)

    if warnings:
        print("=" * 60)
        mode_word = "staged" if args.staged else "commit"
        print(f"⚠ 标题相似度警告（仅警告，不阻断{mode_word}）")
        print("=" * 60)
        for file, reason in warnings:
            print(f"  📄 新文件: {file}")
            print(f"  📋 提示: {reason}")
            print()
        print("如确认是新角度，可继续；如重复，建议：")
        print("  1. 合并到已有 flomo 笔记（追加而非新建）")
        print("  2. 重命名本文档以区分主题")
        print("=" * 60)

    sys.exit(0)


if __name__ == "__main__":
    main()
